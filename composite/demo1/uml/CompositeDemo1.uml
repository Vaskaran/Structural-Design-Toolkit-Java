              <language>JAVA</language>
              <body>&#xD;
    double priceTotal = 0;&#xD;
    for (Item item : items) {&#xD;
        priceTotal += item.price();&#xD;
    }&#xD;
    return priceTotal;&#xD;
</body>
            </ownedBehavior>
