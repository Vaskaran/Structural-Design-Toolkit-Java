    <packagedElement xmi:type="uml:Package" xmi:id="_b69_UOOVEfCe79okyR0BGw" name="sdt">
      <packagedElement xmi:type="uml:Package" xmi:id="_b_LJ4OOVEfCe79okyR0BGw" name="composite">
