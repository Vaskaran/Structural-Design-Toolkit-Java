                <language>JAVA</language>
                <body>new ArrayList&lt;Item>()</body>
              </defaultValue>
            </ownedAttribute>
            <interfaceRealization xmi:type="uml:InterfaceRealization" xmi:id="_b_zcAOOVEfCe79okyR0BGw" client="_b_mnsOOVEfCe79okyR0BGw" supplier="_b_suUOOVEfCe79okyR0BGw" contract="_b_suUOOVEfCe79okyR0BGw"/>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_cAhNsOOVEfCe79okyR0BGw" name="add" specification="_cAL2gOOVEfCe79okyR0BGw">
              <language>JAVA</language>
              <body>&#xD;
